   "source": [
    "import joblib\n",
    "import joblib\n",
    "\n",
    "\n",
    "model = joblib.load('ticket_classifier.joblib')\n",
    "le = joblib.load('le.joblib')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "55876df3",
   "metadata": {},
   "outputs": [],
   "source": [
    "def ask(text:str):\n",
    "    return le.inverse_transform(model.predict([str(text)]))[0]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 28,
   "id": "65f80d04",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Billing and Payments\n"
     ]
    }
   ],
   "source": [
    "text = input(\"Enter ticket body\")\n",
    "print(ask(text))"
   ]
  }
